t(\"verdict\") or {}).get(\"label\") or \"n/a\" for x in buy))}')\n\n# 是否 BUY 的 return 顯著正?\nbuy_hits = [x for x in buy if (x.get('verdict') or {}).get('label')=='hit']\nrets_buy = [((x.get('reality_at_eval') or {}).get('ticker_reality') or {}).get('return_pct') for x in buy]\nrets_buy = [r for r in rets_buy if r is not None]\nprint(f'  BUY-class returns: count={len(rets_buy)} mean={sum(rets_buy)/len(rets_buy):.2f}')\n\nprint()\n# Window completeness analysis\nprint('=== window_complete_pct distribution ===')\nbuckets = Counter()\nfor x in dd:\n    pct = (x.get('reality_at_eval') or {}).get('window_complete_pct')\n    if pct is None: \n        buckets['None'] += 1\n    elif pct >= 100: buckets['>=100'] += 1\n    elif pct >= 75: buckets['75-99'] += 1\n    elif pct >= 50: buckets['50-74'] += 1\n    else: buckets['<50'] += 1\nprint(' ', dict(buckets))\n\n# window_complete ≥100 vs hit rate\nmature = [x for x in dd if (x.get('reality_at_eval') or {}).get('window_complete_pct',0) >= 100]\nprint(f'\\n  matured (>=100%): n={len(mature)}')\nprint(f'  verdicts: {dict(Counter((x.get(\"verdict\") or {}).get(\"label\") or \"n/a\" for x in mature))}')\n\nEOF\n","description":"Caution-class analysis + window maturity"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1837,"cache_read_input_tokens":47892,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1837},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"8f90d9f2-233f-4daa-afb1-031f90aefbf7","uuid":"5ee41fe7-7478-4af6-9c14-a635278e1b21"}
