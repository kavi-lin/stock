ikely most reliable verdicts):\")\nfor d in dd:\n    wp = (d.get('reality_at_eval') or {}).get('window_complete_pct',0)\n    if wp >= 50:\n        label = (d.get('verdict') or {}).get('label')\n        ret = (d.get('reality_at_eval') or {}).get('ticker_reality',{}).get('return_pct')\n        rat = (d.get('verdict') or {}).get('rationale','')[:60]\n        print(f\"  {d['decision_id']} wp={wp}% label={label} ret={ret} | {rat}\")\n\n# E. AMD all decisions\nprint(\"\\nAMD all decisions:\")\nfor d in dd:\n    if 'AMD' in d.get('tickers',[]):\n        s = (d.get('decision_content') or {}).get('final_score')\n        fa = (d.get('decision_content') or {}).get('final_action')\n        ret = (d.get('reality_at_eval') or {}).get('ticker_reality',{}).get('return_pct')\n        label = (d.get('verdict') or {}).get('label')\n        print(f\"  {d['decision_id']} score={s} fa={fa!r} ret={ret} verdict={label}\")\n\n# F. APLD / MSFT / MU repeats\nfor tk in ['MSFT','MU','APLD','MRVL']:\n    print(f\"\\n{tk} all decisions:\")\n    for d in dd:\n        if tk in d.get('tickers',[]):\n            s = (d.get('decision_content') or {}).get('final_score')\n            fa = (d.get('decision_content') or {}).get('final_action')\n            ret = (d.get('reality_at_eval') or {}).get('ticker_reality',{}).get('return_pct')\n            label = (d.get('verdict') or {}).get('label')\n            print(f\"  {d['decision_id']} score={s} fa={fa!r} ret={ret} verdict={label}\")\nEOF\n","description":"Specific decision_id citations for patterns"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2707,"cache_read_input_tokens":59099,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2707},"output_tokens":41,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"054c832e-ab56-41f2-a5c6-08d8c1f51