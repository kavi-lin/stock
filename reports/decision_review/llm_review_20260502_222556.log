e_agent: NA — probably means newer decisions w/ different schema. Cross-check date\nprint(\"\\n=== decisive_agent NA dates ===\")\nna_dates = Counter()\nfor d in dd:\n    if (d.get('tuning_hooks') or {}).get('decisive_agent') is None:\n        na_dates[d['decision_date'][:7]] += 1\nprint(dict(na_dates))\n\nprint(\"\\n=== decisive_agent populated dates ===\")\npop_dates = Counter()\nfor d in dd:\n    da = (d.get('tuning_hooks') or {}).get('decisive_agent')\n    if da:\n        pop_dates[d['decision_date'][:7]] += 1\nprint(dict(pop_dates))\n\n# all unique tickers in deep-dive\nticks = Counter()\nfor d in dd:\n    for t in d.get('tickers',[]):\n        ticks[t] += 1\nprint(\"\\n=== Repeated tickers in deep-dive (>=2) ===\")\nfor t,c in ticks.most_common():\n    if c >= 2:\n        print(f\"  {t}: {c}\")\nEOF\n","description":"Detailed deep-dive verdict analysis"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2293,"cache_read_input_tokens":45871,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2293},"output_tokens":53,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"054c832e-ab56-41f2-a5c6-08d8c1f514a6","uuid":"24b4b678-7dab-4aa4-85f7-660be28c3cae"}
