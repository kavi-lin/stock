{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01S8CT1yaWQiaiU6QaEs89RB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011nhR2auvZvAJHrM52NiUPn","name":"Bash","input":{"command":"python3 <<'PY'\nimport json\nfrom collections import Counter, defaultdict\n\nwith open(\"reports/decision_review/event_index_latest.json\") as f:\n    data = json.load(f)\ndecs = [d for d in data[\"decisions\"] if d[\"source\"]==\"deep-dive\"]\nprint(f\"deep-dive total: {len(decs)}\")\n\n# stratify by decisive_agent\nda = defaultdict(Counter)\nfor d in decs:\n    a = (d.get(\"tuning_hooks\") or {}).get(\"decisive_agent\",\"n/a\")\n    v = (d.get(\"verdict\") or {}).get(\"label\",\"n/a\")\n    da[a][v]+=1\nprint(\"\\n--- by decisive_agent ---\")\nfor a, vc in sorted(da.items(), key=lambda x:-sum(x[1].values())):\n    total=sum(vc.values())\n    line = \", \".join(f\"{k}={v}\" for k,v in vc.most_common())\n    hit=vc.get(\"hit\",0); miss=vc.get(\"miss\",0)\n    decided = hit+miss\n    rate = f\"hitR={hit/decided:.2%}\" if decided else \"n/a\"\n    print(f\"  {a} (n={total}, {rate}): {line}\")\n\n# by final_action\nfa = defaultdict(Counter)\nfor d in decs:\n    a = (d.get(\"decision_content\") or {}).get(\"final_action\",\"n/a\")\n    v = (d.get(\"verdict\") or {}).get(\"label\",\"n/a\")\n    fa[str(a)][v]+=1\nprint(\"\\n--- by final_action ---\")\nfor a, vc in sorted(fa.items(), key=lambda x:-sum(x[1].values())):\n    total=sum(vc.values())\n    line = \", \".join(f\"{k}={v}\" for k,v in vc.most_common())\n    hit=vc.get(\"hit\",0); miss=vc.get(\"miss\",0)\n    decided = hit+miss\n    rate = f\"hitR={hit/decided:.2%}\" if decided else \"n/a\"\n    print(f\"  action={a} (n={total}, {rate}): {line}\")\n\n# by final_score buckets\ndef bucket(s):\n    if s is None: return \"none\"\n    if s<=-2: return \"<=-2 strong sell\"\n    if s<=-0.5: return \"-2..-0.5 weak sell\"\n    if s<0.5: return \"-0.5..0.5 hold\"\n    if s<2: return \"0.5..2 weak buy\"\n    return \">=2 strong buy\"\n\nsb = defaultdict(Counter)\nfor d in decs:\n    s = (d.get(\"decision_content\") or {}).get(\"final_score\")\n    v = (d.get(\"verdict\") or {}).get(\"label\",\"n/a\")\n    sb[bucket(s)][v]+=1\nprint(\"\\n--- by final_score bucket ---\")\nfor a, vc in sb.items():\n    total=sum(vc.values())\n    line = \", \".join(f\"{k}={v}\" for k,v in vc.most_common())\n    hit=vc.get(\"hit\",0); miss=vc.get(\"miss\",0)\n    decided = hit+miss\n    rate = f\"hitR={hit/decided:.2%}\" if decided else \"n/a\"\n    print(f\"  {a} (n={total}, {rate}): {line}\")\n\n# window completeness\nwc = defaultdict(Counter)\nfor d in decs:\n    p = (d.get(\"reality_at_eval\") or {}).get(\"window_complete_pct\",0)\n    if p>=100: b=\"full(>=100)\"\n    elif p>=80: b=\"late(80-99)\"\n    elif p>=50: b=\"mid(50-79)\"\n    else: b=\"early(<50)\"\n    v = (d.get(\"verdict\") or {}).get(\"label\",\"n/a\")\n    wc[b][v]+=1\nprint(\"\\n--- by window_complete_pct ---\")\nfor b in [\"full(>=100)\",\"late(80-99)\",\"mid(50-79)\",\"early(<50)\"]:\n    if b in wc:\n        vc = wc[b]\n        total=sum(vc.values())\n        hit=vc.get(\"hit\",0); miss=vc.get(\"miss\",0)\n        decided = hit+miss\n        rate = f\"hitR={hit/decided:.2%}\" if decided else \"n/a\"\n        line = \", \".join(f\"{k}={v}\" for k,v in vc.most_common())\n        print(f\"  {b} (n={total}, {rate}): {line}\")\nPY","description":"Stratify deep-dive verdicts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":904,"cache_read_input_tokens":44723,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":904},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"08616262-1ed4-4d4a-8317-733dd033554e","uuid":"a3d651c5-364b-4b3a-9280-0c62f9ef978a"}
