et(d) is not None]\nprint(f'None action: n={len(returns)}, mean={statistics.mean(returns):.2f}%, median={statistics.median(returns):.2f}%')\n\n# SPY-comparable: average return across all deep-dive \nall_ret = [get_ret(d) for d in dd if get_ret(d) is not None]\nprint(f'\\nALL deep-dive: n={len(all_ret)}, mean_ret={statistics.mean(all_ret):.2f}% median={statistics.median(all_ret):.2f}%')\n\nEOF","description":"Action class returns"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1662,"cache_read_input_tokens":66400,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1662},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1114e8dd-8215-4c3a-99a5-cdeff879e5e6","uuid":"425caa24-83f7-4944-84f6-c1fd9566ffad"}
