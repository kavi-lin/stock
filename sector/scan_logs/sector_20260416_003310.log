{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VTqURk7U8e12336WgmD2RB","type":"tool_result","content":"1\t# JSON Schema Reference\n2\t\n3\t> 所有 Phase 的 JSON 輸出 schema。執行各 Phase 寫入 JSON 時按需查閱。\n4\t> ⚠️ Phase 5 的 `_phase0`、`_phase1`、`_phase3` key 名稱不可更換（bridge.py 依賴）。\n5\t\n6\t---\n7\t\n8\t## Phase 0 Schema\n9\t\n10\t```json\n11\t{\n12\t  \"phase\": 0,\n13\t  \"agent\": \"Macro_Regime_Analyst\",\n14\t  \"scan_date\": \"YYYY-MM-DD\",\n15\t  \"breadth_source\": \"market-breadth-analyzer | web_search\",\n16\t  \"breadth_score\": \"float 0–100\",\n17\t  \"breadth_zone\": \"Strong | Healthy | Neutral | Weakening | Critical\",\n18\t  \"breadth_components\": {\n19\t    \"overall_breadth\": \"0–100\",\n20\t    \"sector_participation\": \"0–100\",\n21\t    \"momentum\": \"0–100\",\n22\t    \"mean_reversion_risk\": \"0–100\"\n23\t  },\n24\t  \"market_regime\": \"BULL | BEAR | SIDEWAYS | VOLATILE | RISK_OFF | RISK_ON\",\n25\t  \"cycle_phase\": \"Early | Mid | Late | Recession\",\n26\t  \"uptrend_ratio_overall\": \"float 0.0–1.0 (由 Phase 1 回填)\",\n27\t  \"warning_flags\": [\"Bearish_Signal_Active\", \"Below_200MA\", \"Low_Historical_Percentile\"],\n28\t  \"exposure_ceiling\": \"string 如 40-60% (breadth only)\",\n29\t  \"regime_confidence\": \"float 0.0–1.0\",\n30\t  \"ftd\": {\n31\t    \"state\": \"FTD_CONFIRMED | FTD_WINDOW | RALLY_ATTEMPT | CORRECTION | FTD_INVALIDATED | NO_SIGNAL\",\n32\t    \"quality_score\": \"float 0–100\",\n33\t    \"exposure_range\": \"0-20% | 20-40% | 40-65% | 65-100%\",\n34\t    \"source\": \"ftd_cache | not_available\"\n35\t  },\n36\t  \"market_top\": {\n37\t    \"composite_score\": \"float 0–100\",\n38\t    \"zone\": \"Normal | Early_Warning | Elevated_Risk | High_Probability | Top_Formation\",\n39\t    \"risk_budget\": \"string 如 80-100%\",\n40\t    \"source\": \"market_top_cache | not_available\"\n41\t  },\n42\t  \"synthesized_exposure\": \"string — 最保守曝險上限（三訊號最低者）\",\n43\t  \"signal_conflict\": \"true | false\"\n44\t}\n45\t```\n46\t\n47\t---\n48\t\n49\t## Phase 1 Schema\n50\t\n51\t```json\n52\t{\n53\t  \"phase\": 1,\n54\t  \"agent\": \"Sector_Rotation_Analyst\",\n55\t  \"cycle_position\": \"Early | Mid | Late | Recession\",\n56\t  \"sectors\": [\n57\t    {\n58\t      \"name\": \"Technology | Healthcare | Energy | Financials | Consumer_Discretionary | Consumer_Staples | Industrials | Materials | Utilities | Real_Estate | Communication\",\n59\t      \"uptrend_ratio\": \"float 0.0–1.0\",\n60\t      \"uptrend_ratio_vs_ma10\": \"above | below\",\n61\t      \"slope\": \"rising | flat | falling\",\n62\t      \"cyclical_or_defensive\": \"cyclical | defensive\",\n63\t      \"rotation_signal\": \"INFLOW | NEUTRAL | OUTFLOW\",\n64\t      \"overbought_risk\": \"HIGH | MEDIUM | LOW\",\n65\t      \"oversold_opportunity\": \"HIGH | MEDIUM | LOW\"\n66\t    }\n67\t  ],\n68\t  \"hot_sectors\": [\"sector1\", \"sector2\"],\n69\t  \"cold_sectors\": [\"sector1\", \"sector2\"],\n70\t  \"rotation_theme\": \"string — 一句話描述當前輪動方向\"\n71\t}\n72\t```\n73\t\n74\t---\n75\t\n76\t## Phase 2 Schema\n77\t\n78\t```json\n79\t{\n80\t  \"phase\": 2,\n81\t  \"agent\": \"Theme_Intelligence_Analyst\",\n82\t  \"themes\": [\n83\t    {\n84\t      \"name\": \"string\",\n85\t      \"direction\": \"bullish | bearish\",\n86\t      \"heat_score\": \"0–100\",\n87\t      \"lifecycle_stage\": \"Emerging | Accelerating | Trending | Mature | Exhausting\",\n88\t      \"lifecycle_maturity\": \"0–100\",\n89\t      \"confidence\": \"Low | Medium | High\",\n90\t      \"proxy_etfs\": [\"ETF1\", \"ETF2\"],\n91\t      \"representative_stocks\": [\"TICKER1\", \"TICKER2\"],\n92\t      \"cross_sector_reach\": [\"sector1\", \"sector2\"]\n93\t    }\n94\t  ],\n95\t  \"dominant_bullish_theme\": \"string\",\n96\t  \"dominant_bearish_theme\": \"string\"\n97\t}\n98\t```\n99\t\n100\t---\n101\t\n102\t## Phase 3 Schema\n103\t\n104\t```json\n105\t{\n106\t  \"phase\": 3,\n107\t  \"agent\": \"News_Catalyst_Analyst\",\n108\t  \"scan_window\": \"past 10 days + next 7 days\",\n109\t  \"top_catalysts\": [\n110\t    {\n111\t      \"rank\": 1,\n112\t      \"event\": \"string\",\n113\t      \"type\": \"FOMC | earnings | geopolitical | macro_data | sector_specific | political\",\n114\t      \"impact_score\": \"1–5\",\n115\t      \"affected_sectors\": [\"sector1\"],\n116\t      \"direction\": \"bullish | bearish | binary\",\n117\t      \"timing\": \"past | within_48h | this_week | beyond\"\n118\t    }\n119\t  ],\n120\t  \"political_overlay\": {\n121\t    \"trump_trade_signals\": [\n122\t      {\n123\t        \"keyword\": \"tariff | energy_deregulation | immigration | china_threat | pharma_threat\",\n124\t        \"headline\": \"string\",\n125\t        \"source\": \"X | Truth_Social_secondary | news_report\",\n126\t        \"affected_sectors\": [\"sector1\"],\n127\t        \"direction\": \"bullish | bearish\"\n128\t      }\n129\t    ],\n130\t    \"named_targets_today\": [\"TICKER or COUNTRY被點名受威脅\"],\n131\t    \"fear_greed_index\": \"float 0–100\",\n132\t    \"fear_greed_label\": \"Extreme_Fear | Fear | Neutral | Greed | Extreme_Greed\",\n133\t    \"vix_current\": \"float\",\n134\t    \"put_call_ratio\": \"float\",\n135\t    \"spy_rsi\": \"float\",\n136\t    \"sentiment_source\": \"SKILL_EXECUTED | WEB_SEARCH_FALLBACK\",\n137\t    \"extreme_sentiment_triggered\": \"true | false\"\n138\t  },\n139\t  \"upcoming_binary_risks\": [\n140\t    {\n141\t      \"event\": \"string\",\n142\t      \"date\": \"YYYY-MM-DD\",\n143\t      \"affected_sectors\": [],\n144\t      \"within_48h\": \"true | false\"\n145\t    }\n146\t  ],\n147\t  \"sector_news_sentiment\": {\n148\t    \"Technology\": \"bullish | bearish | neutral\",\n149\t    \"Healthcare\": \"bullish | bearish | neutral\"\n150\t  }\n151\t}\n152\t```\n153\t\n154\t---\n155\t\n156\t## Phase 4a Schema\n157\t\n158\t```json\n159\t{\n160\t  \"phase\": \"4a\",\n161\t  \"agent\": \"Sector_Rotation_Analyst | Theme_Intelligence_Analyst | News_Catalyst_Analyst\",\n162\t  \"top_conviction_hot\": [\"