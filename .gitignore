# macOS
.DS_Store
.localized

# User portfolio data (never commit)
positions.json

# Persistent events archive — accumulates daily, regenerable from FMP/Fed feeds
events_archive.json

# Log files with sensitive data — keep structure but ignore actual content
news/news_logs/*.json
sector/sector_logs/*.json
investment/invest_logs/history.json
investment/invest_logs/*_phase0.json
investment/invest_logs/*_phase0_*.json
investment/invest_logs/*.md

# Third-party reference repos (read-only, not part of protocol)
reference/

# Claude Code scheduled task lock (local state)
.claude/scheduled_tasks.lock

# Python bytecode
__pycache__/
*.py[cod]

# Claude CLI stream-json scan logs (large, not source)
investment/scan_logs/
news/scan_logs/
sector/scan_logs/

# Per-skill runtime caches (generated on demand, not source)
skills/*/cache/

# Per-skill journal (forward-return tracking, local to each machine)
skills/*/journal/

# Claude Code local settings (machine-specific allowlists)
.claude/settings.local.json

# Keep directory structure
!news/news_logs/.gitkeep
!sector/sector_logs/.gitkeep
!investment/invest_logs/.gitkeep
